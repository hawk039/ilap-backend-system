APP_NAME=ILAP Platform Backend
APP_VERSION=1.0.0
ENVIRONMENT=development
API_PREFIX=/api/v1
DEBUG=false
AUTO_CREATE_SCHEMA=true

DATABASE_URL=sqlite:///./storage/ilap.db
SYNC_DATABASE_URL=sqlite:///./storage/ilap.db

JWT_SECRET_KEY=replace-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_HOURS=24

AI_SERVICE_BASE_URL=http://127.0.0.1:9000
AI_SERVICE_TIMEOUT_SECONDS=20
AI_STUB_MODE=true

CORS_ORIGINS=["http://localhost:3000"]

LOGIN_RATE_LIMIT_PER_MINUTE=10
REGISTER_RATE_LIMIT_PER_MINUTE=10
FORGOT_PASSWORD_RATE_LIMIT_PER_HOUR=5
ASK_RATE_LIMIT_PER_MINUTE=30

ADMIN_BOOTSTRAP_EMAIL=admin@ilap.local
ADMIN_BOOTSTRAP_PASSWORD=replace-this-password
